# Cloudflare Images account hash — public; appears in every delivery URL.
# Used by the app at build time (Vite inlines it into the client bundle).
VITE_CLOUDFLARE_IMAGES_HASH=

# Cloudflare account id + an API token with "Images: Edit".
# Used only by `npm run photos` (the upload script); not needed at runtime.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_TOKEN=
